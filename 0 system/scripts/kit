#!/usr/bin/env bash
set -euo pipefail

ROOT_MARKER=".kitos-root"

if [ ! -f "$ROOT_MARKER" ]; then
  echo "This command only runs inside the kitOS personal workspace root."
  exit 1
fi

cmd="${1:-}"
shift || true

case "$cmd" in
  run)
    flow="${1:-}"
    case "$flow" in
      todo)
        ./"0 system/scripts/inbox_process.sh" "${@:2}"
        ;;
      review)
        ./"0 system/scripts/review_process.sh"
        ;;
      *)
        echo "Usage: ./0 system/scripts/kit run <todo|review> [--force]"
        exit 1
        ;;
    esac
    ;;
  kickoff)
    ./"0 system/scripts/new_project.sh" "${1:-new-project}"
    ;;
  capture)
    ./"0 system/scripts/new_task.sh" "$*"
    ;;
  next)
    ./"0 system/scripts/next_task.sh"
    ;;
  review)
    if [ $# -eq 0 ]; then
      ./"0 system/scripts/review_process.sh"
    else
      ./"0 system/scripts/promote_task.sh" "1 todo/${1:?task filename required}" review
    fi
    ;;
  archive)
    ./"0 system/scripts/promote_task.sh" "1 review/${1:?task filename required}" archive
    ;;
  digest)
    ./"0 system/scripts/weekly_review.sh"
    ;;
  insight)
    ./"0 system/scripts/inbox_process.sh"
    ;;
  backup)
    ./"0 system/scripts/backup_workspace.sh"
    ;;
  cleanup)
    ./"0 system/scripts/cleanup_audit.sh"
    ;;
  watch)
    ./"0 system/scripts/watch_inbox.sh"
    ;;
  *)
    echo "Usage: ./0 system/scripts/kit <run|kickoff|capture|next|review|archive|digest|insight|backup|cleanup|watch> [args]"
    echo "Flow:  ./0 system/scripts/kit run <todo|review> [--force]"
    exit 1
    ;;
esac
